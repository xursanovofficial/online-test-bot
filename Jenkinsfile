pipeline {
    agent any
    
    stages {
        stage('Salomlashish') {
            steps {
                echo 'Salom! Bu mening birinchi Jenkins pipeline-im.'
            }
        }
        
        stage('Sana') {
            steps {
                sh 'date'
            }
        }
        
        stage('Disk holati') {
            steps {
                sh 'df -h'
            }
        }
    }
}